alias ska-update-simple='ska && make update && make install'
ska-update-advanced() {
    # Interactive upstream-merge workflow for forked SkillArch setups.
    cd /opt/skillarch 2>/dev/null || { echo "No /opt/skillarch — clone your fork there first."; return 1; }
    git remote get-url upstream >/dev/null 2>&1 || { echo "Add upstream first:  git remote add upstream https://github.com/laluka/skillarch.git"; return 1; }
    [[ "$(git rev-parse --abbrev-ref HEAD)" == "main" ]] || { echo "Not on main — switch first."; return 1; }
    local ans msg incoming
    # Loud banner for the heavy full-patch sections
    _skau_banner() {
        printf '\n\033[1;35m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\n┃  %-69s  ┃\n┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m\n\n' "$1"
    }
    # 1. Local changes → offer to commit + push
    if [[ -n "$(git status --porcelain)" ]]; then
        echo "── Local changes ──"; git status --short
        printf "Commit + push these first? [Y/n] "; read -r ans
        if [[ -z "$ans" || "$ans" == [Yy]* ]]; then
            printf "Commit message: "; read -r msg
            git add -A && git commit -m "${msg:-wip: local changes}" && git push origin main || return 1
        else
            echo "Abort — stash or commit first."; return 1
        fi
    fi
    # 2. Fetch + preview incoming
    git fetch upstream || return 1
    incoming=$(git log --oneline main..upstream/main)
    if [[ -z "$incoming" ]]; then echo "Already up to date with upstream/main."; return 0; fi
    echo "── Incoming commits (graph) ──"
    git --no-pager log --graph --decorate --oneline main..upstream/main
    echo; echo "── Overall diff stat ──"
    git --no-pager diff --stat main upstream/main
    _skau_banner "FULL INCOMING PATCH   (main..upstream/main)"
    git --no-pager log --patch --stat main..upstream/main
    # 3. Merge
    printf "\nMerge upstream/main into main? [Y/n] "; read -r ans
    [[ -z "$ans" || "$ans" == [Yy]* ]] || { echo "Abort."; return 1; }
    git merge upstream/main || { echo "Merge conflict — resolve$(:) then push + ska-update-simple manually."; return 1; }
    # 4. Post-merge preview — what's about to leave your fork
    echo; echo "── Merge result (last 10 commits on main) ──"
    git --no-pager log --graph --decorate --oneline -n 10
    echo; echo "── Outgoing commits (origin/main..HEAD) ──"
    git --no-pager log --oneline origin/main..HEAD
    echo; echo "── Outgoing diff stat vs origin/main ──"
    git --no-pager diff --stat origin/main..HEAD
    _skau_banner "FULL OUTGOING PATCH   (origin/main..HEAD)"
    git --no-pager diff origin/main..HEAD
    # 5. Push + reapply
    printf "\nPush merge to origin/main? [Y/n] "; read -r ans
    [[ -z "$ans" || "$ans" == [Yy]* ]] && { git push origin main || return 1; }
    printf "Run ska-update-simple to reapply install? [Y/n] "; read -r ans
    [[ -z "$ans" || "$ans" == [Yy]* ]] && ska-update-simple
    # 6. Final drift vs upstream — your fork's divergence after the merge
    echo; echo "── Final drift: your commits not in upstream/main ──"
    git --no-pager log --oneline upstream/main..HEAD
    echo; echo "── Drift diff stat vs upstream/main ──"
    git --no-pager diff --stat upstream/main..HEAD
    _skau_banner "FULL DRIFT PATCH      (upstream/main..HEAD)"
    git --no-pager diff upstream/main..HEAD
    unfunction _skau_banner
    echo
    echo "── Stay in the loop ──"
    echo "Join the SkillArch channel on OffenSkill's Discord for news, help & latest tweaks:"
    echo "  https://discord.gg/2T8GGAnwv5"
}
